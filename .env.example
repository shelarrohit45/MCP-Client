# Copy this file to .env and fill in your values.
# Never commit .env to git.

# GitHub — https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=

# Repo (must match your GitHub repo)
GITHUB_OWNER=shelarrohit45
GITHUB_REPO=MCP-Client

# Email — app password for the SENDER account only (see config/config.yaml)
EMAIL_PASSWORD=

# Gmail defaults (change if using Outlook/other)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993

# PR action links in email (generate with: openssl rand -hex 32)
ACTION_SECRET=
ACTION_BASE_URL=http://127.0.0.1:8765
ACTION_PORT=8765
